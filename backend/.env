# ========= Server Settings =========
PORT=5000

# ========= MongoDB Connection =========
# For local MongoDB installation
MONGO_URI=mongodb://127.0.0.1:27017/sirrs

# If using MongoDB Atlas instead of local, comment the above line and use:
# MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/sirrs?retryWrites=true&w=majority

# ========= JWT Authentication =========
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ========= SMTP Settings (for email notifications - optional) =========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=noreply@sirrs.com